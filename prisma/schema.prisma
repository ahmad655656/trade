generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String
  name          String
  role          Role       @default(TRADER)
  phone         String?
  avatar        String?
  twoFactorAuth Boolean    @default(false)
  twoFactorSecret String?
  emailNotifications Boolean @default(false)
  lastLogin     DateTime?
  status        UserStatus @default(ACTIVE)

  supplier            Supplier?
  trader              Trader?
  admin               Admin?
  wallet              Wallet?
  addresses           Address[]
  notifications       Notification[]
  reviews             Review[]                  @relation("Reviewer")
  sentMessages        Message[]                 @relation("MessageSender")
  conversationMembers ConversationParticipant[]
  timelineEvents      OrderTimelineEvent[]      @relation("TimelineActor")
  auditLogs           AuditLog[]                @relation("AuditActor")
  securityEvents      SecurityEvent[]
  loginAttempts       LoginAttempt[]
  reviewedVerifications SupplierVerification[]  @relation("VerificationReviewer")
  disputeMessages     DisputeMessage[]          @relation("DisputeMessageAuthor")
  disputeAttachments  DisputeAttachment[]       @relation("DisputeAttachmentUploader")
  resolvedDisputes    Dispute[]                 @relation("DisputeResolver")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id                 String       @id @default(cuid())
  userId             String       @unique
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName        String
  commercialRegister String?
  taxNumber          String?
  businessType       BusinessType?
  description        String?
  logo               String?
  coverImage         String?
  verified           Boolean      @default(false)
  rating             Float        @default(0)
  totalReviews       Int          @default(0)
  totalProducts      Int          @default(0)
  totalOrders        Int          @default(0)
  totalSales         Float        @default(0)
  commissionRate     Float?

  shippingMethods ShippingMethod[]
  bankAccounts    BankAccount[]
  products        Product[]
  orders          OrderItem[]      @relation("SupplierOrders")
  reviews         Review[]         @relation("SupplierReviews")
  withdrawals     Withdrawal[]
  verification    SupplierVerification?
  rfqQuotes       RfqQuote[]
  favoriteItems   FavoriteListItem[]
  disputes        Dispute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trader {
  id           String       @id @default(cuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  businessType BusinessType?
  taxNumber    String?
  totalOrders  Int          @default(0)
  totalSpent   Float        @default(0)

  orders   Order[]
  cart     Cart?
  wishlist WishlistItem[]
  rfqs     Rfq[]
  favoriteLists FavoriteList[]
  disputes Dispute[]
  verification TraderVerification?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TraderVerification {
  id        String                     @id @default(cuid())
  traderId  String                     @unique
  trader    Trader                     @relation(fields: [traderId], references: [id], onDelete: Cascade)
  status    SupplierVerificationStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id            String       @id @default(cuid())
  supplierId    String
  supplier      Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name          String
  nameAr        String?
  nameEn        String?
  description   String?
  descriptionAr String?
  descriptionEn String?
  categoryId    String
  category      Category     @relation(fields: [categoryId], references: [id])
  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])
  tags          String[]
  price         Float
  compareAtPrice Float?
  cost          Float?
  quantity      Int
  sku           String?
  barcode       String?
  minOrderQuantity Int       @default(1)
  images        String[]
  video         String?
  specifications Json?
  weight        Float?
  dimensions    String?
  status        ProductStatus @default(ACTIVE)
  featured      Boolean      @default(false)
  views         Int          @default(0)
  soldCount     Int          @default(0)
  rating        Float        @default(0)
  reviewCount   Int          @default(0)

  variants   ProductVariant[]
  reviews    Review[]
  orderItems OrderItem[]
  wishlists  WishlistItem[]
  cartItems  CartItem[]
  favoriteListItems FavoriteListItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributes Json
  price      Float?
  quantity   Int
  sku        String?
  image      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id            String   @id @default(cuid())
  name          String
  nameAr        String?
  nameEn        String?
  slug          String   @unique
  description   String?
  image         String?
  icon          String?
  parentId      String?
  parent        Category? @relation("CategoryToCategory", fields: [parentId], references: [id])
  children      Category[] @relation("CategoryToCategory")
  products      Product[]
  subcategories Subcategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subcategory {
  id         String   @id @default(cuid())
  name       String
  nameAr     String?
  nameEn     String?
  slug       String   @unique
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  products   Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                String        @id @default(cuid())
  orderNumber       String        @unique
  traderId          String
  trader            Trader        @relation(fields: [traderId], references: [id])
  items             OrderItem[]
  totalAmount       Float
  subtotal          Float
  tax               Float         @default(0)
  shipping          Float         @default(0)
  discount          Float         @default(0)
  commission        Float         @default(0)
  platformFee       Float         @default(0)
  platformFeeRate   Float         @default(0)
  status            OrderStatus   @default(PENDING_PLATFORM_FEE_PAYMENT)
  paymentStatus     PaymentStatus @default(PENDING)
  shippingStatus    ShippingStatus @default(PENDING)
  shippingAddressId String?
  address           Address?      @relation(fields: [shippingAddressId], references: [id])
  shippingMethod    String?
  trackingNumber    String?
  estimatedDelivery DateTime?
  deliveredAt       DateTime?
  payment           Payment?
  paymentMethod     String?
  transactionId     String?
  confirmedAt       DateTime?
  processedAt       DateTime?
  shippedAt         DateTime?
  merchantConfirmedAt DateTime?
  closedAt          DateTime?
  disputeOpenedAt   DateTime?
  cancelledAt       DateTime?
  cancelledReason   String?
  supplierPaymentConfirmedAt DateTime?

  invoice Invoice?
  reviews Review[]
  timelineEvents OrderTimelineEvent[]
  disputes Dispute[]
  conversations Conversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id         String    @id @default(cuid())
  orderId    String
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product   @relation(fields: [productId], references: [id])
  supplierId String
  supplier   Supplier  @relation("SupplierOrders", fields: [supplierId], references: [id])
  quantity   Int
  price      Float
  total      Float
  commission Float
  variant    Json?
  status     OrderItemStatus @default(PENDING)
  refunded   Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id             String        @id @default(cuid())
  orderId        String        @unique
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  purpose        PaymentPurpose @default(PLATFORM_FEE)
  amount         Float
  platformFee    Float
  supplierAmount Float
  status         PaymentStatus @default(PENDING)
  method         PaymentMethod
  transactionId  String?
  verifiedByAdminId String?
  verifiedAt     DateTime?
  paidAt         DateTime?
  refundedAt     DateTime?
  refundReason   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wallet {
  id             String  @id @default(cuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance        Float   @default(0)
  pendingBalance Float   @default(0)
  totalEarned    Float   @default(0)
  totalWithdrawn Float   @default(0)

  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id          String            @id @default(cuid())
  walletId    String
  wallet      Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Float
  description String?
  referenceId String?
  status      TransactionStatus @default(PENDING)

  createdAt DateTime @default(now())
}

model Withdrawal {
  id            String           @id @default(cuid())
  supplierId    String
  supplier      Supplier         @relation(fields: [supplierId], references: [id])
  amount        Float
  bankAccountId String?
  bankAccount   BankAccount?     @relation(fields: [bankAccountId], references: [id])
  status        WithdrawalStatus @default(PENDING)
  notes         String?
  processedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BankAccount {
  id            String   @id @default(cuid())
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  bankName      String
  accountName   String
  accountNumber String
  iban          String?
  swift         String?
  isDefault     Boolean  @default(false)

  withdrawals Withdrawal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShippingMethod {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name        String
  description String?
  fee         Float    @default(0)
  estimatedDays Int?
  isActive    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cart {
  id          String   @id @default(cuid())
  traderId    String   @unique
  trader      Trader   @relation(fields: [traderId], references: [id], onDelete: Cascade)
  items       CartItem[]
  totalItems  Int      @default(0)
  totalAmount Float    @default(0)

  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WishlistItem {
  id        String  @id @default(cuid())
  traderId  String
  trader    Trader  @relation(fields: [traderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@unique([traderId, productId])
}

model Review {
  id           String    @id @default(cuid())
  orderId       String?  @unique
  order         Order?   @relation(fields: [orderId], references: [id])
  fromUserId    String
  fromUser      User     @relation("Reviewer", fields: [fromUserId], references: [id])
  toSupplierId  String?
  toSupplier    Supplier? @relation("SupplierReviews", fields: [toSupplierId], references: [id])
  toProductId   String?
  toProduct     Product? @relation(fields: [toProductId], references: [id])
  rating        Int
  qualityRating Int?
  deliverySpeedRating Int?
  descriptionAccuracyRating Int?
  communicationRating Int?
  title         String?
  comment       String?
  images        String[]
  reply         String?
  replyDate     DateTime?
  helpful       Int      @default(0)
  status        ReviewStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id            String        @id @default(cuid())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  invoiceNumber String        @unique
  status        InvoiceStatus @default(ISSUED)
  currency      String        @default("SYP")
  subtotal      Float
  tax           Float         @default(0)
  shipping      Float         @default(0)
  discount      Float         @default(0)
  total         Float
  issuedAt      DateTime      @default(now())
  pdfUrl        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([invoiceNumber])
}

model SupplierVerification {
  id              String                     @id @default(cuid())
  supplierId      String                     @unique
  supplier        Supplier                   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  status          SupplierVerificationStatus @default(PENDING)
  phoneVerified   Boolean                    @default(false)
  addressVerified Boolean                    @default(false)
  reviewedById    String?
  reviewedBy      User?                      @relation("VerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  rejectionReason String?
  reviewedAt      DateTime?
  documents       SupplierVerificationDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupplierVerificationDocument {
  id             String                   @id @default(cuid())
  verificationId String
  verification   SupplierVerification     @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  type           VerificationDocumentType
  fileUrl        String
  verified       Boolean                  @default(false)
  notes          String?

  createdAt DateTime @default(now())

  @@index([verificationId, type])
}

model OrderTimelineEvent {
  id          String     @id @default(cuid())
  orderId     String
  order       Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      OrderStatus
  title       String
  note        String?
  actorUserId String?
  actor       User?      @relation("TimelineActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  metadata    Json?

  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

model AuditLog {
  id          String @id @default(cuid())
  actorUserId String?
  actor       User?  @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorRole   Role?
  action      String
  entityType  String
  entityId    String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Dispute {
  id                String        @id @default(cuid())
  orderId           String
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  traderId          String
  trader            Trader        @relation(fields: [traderId], references: [id], onDelete: Cascade)
  supplierId        String?
  supplier          Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  reason            DisputeReason
  status            DisputeStatus @default(OPEN)
  description       String
  resolutionSummary String?
  resolvedById      String?
  resolvedBy        User?         @relation("DisputeResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  openedAt          DateTime      @default(now())
  resolvedAt        DateTime?
  messages          DisputeMessage[]
  attachments       DisputeAttachment[]

  @@index([orderId])
  @@index([status, openedAt])
}

model DisputeMessage {
  id          String  @id @default(cuid())
  disputeId   String
  dispute     Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  authorId    String
  author      User    @relation("DisputeMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  message     String
  attachments String[]

  createdAt DateTime @default(now())

  @@index([disputeId, createdAt])
}

model DisputeAttachment {
  id           String   @id @default(cuid())
  disputeId    String
  dispute      Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  fileUrl      String
  uploadedById String?
  uploadedBy   User?    @relation("DisputeAttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([disputeId])
}

model Rfq {
  id               String    @id @default(cuid())
  traderId         String
  trader           Trader    @relation(fields: [traderId], references: [id], onDelete: Cascade)
  productRequest   String
  quantity         Int
  deliveryLocation String
  notes            String?
  status           RfqStatus @default(OPEN)
  expiresAt        DateTime?
  quotes           RfqQuote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([traderId, createdAt])
}

model RfqQuote {
  id                    String   @id @default(cuid())
  rfqId                 String
  rfq                   Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  supplierId            String
  supplier              Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  price                 Float
  availableQuantity     Int
  estimatedShippingDays Int
  notes                 String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([rfqId, supplierId])
}

model FavoriteList {
  id       String   @id @default(cuid())
  traderId String
  trader   Trader   @relation(fields: [traderId], references: [id], onDelete: Cascade)
  name     String
  items    FavoriteListItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([traderId, name])
}

model FavoriteListItem {
  id         String             @id @default(cuid())
  listId     String
  list       FavoriteList       @relation(fields: [listId], references: [id], onDelete: Cascade)
  targetType FavoriteTargetType
  productId  String?
  product    Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplierId String?
  supplier   Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([listId, targetType])
}

model LoginAttempt {
  id        String  @id @default(cuid())
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  ipAddress String?
  userAgent String?
  success   Boolean

  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

model SecurityEvent {
  id          String            @id @default(cuid())
  userId      String?
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  type        SecurityEventType
  severity    Int               @default(1)
  description String
  ipAddress   String?
  userAgent   String?
  metadata    Json?

  createdAt DateTime @default(now())

  @@index([type, createdAt])
}

model Address {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       AddressType @default(HOME)
  title      String
  recipient  String
  phone      String
  country    String
  city       String
  state      String?
  address    String
  postalCode String?
  latitude   Float?
  longitude  Float?
  isDefault  Boolean     @default(false)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id      String           @id @default(cuid())
  userId  String
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type    NotificationType
  title   String
  message String?
  data    Json?
  read    Boolean          @default(false)
  readAt  DateTime?

  createdAt DateTime @default(now())
}

model Conversation {
  id            String                    @id @default(cuid())
  orderId       String?
  order         Order?                    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  lastMessage   String?
  lastMessageAt DateTime?

  participants ConversationParticipant[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  content        String
  attachments    String[]
  read           Boolean      @default(false)
  readAt         DateTime?

  createdAt DateTime @default(now())
}

model Setting {
  id          String @id @default(cuid())
  key         String @unique
  value       Json
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  SUPPLIER
  TRADER
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  BANNED
}

enum BusinessType {
  RETAIL
  WHOLESALE
  MANUFACTURER
  DISTRIBUTOR
  SERVICE_PROVIDER
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  DRAFT
  PENDING_REVIEW
  REJECTED
}

enum OrderStatus {
  PENDING_PLATFORM_FEE_PAYMENT
  WAITING_FOR_PAYMENT_VERIFICATION
  PLATFORM_FEE_CONFIRMED
  WAITING_FOR_ADMIN_REVIEW
  ADMIN_APPROVED
  ADMIN_REJECTED
  SUPPLIER_PREPARING_ORDER
  SHIPPED
  AWAITING_DELIVERY_CONFIRMATION
  DELIVERED
  SUPPLIER_PAYMENT_CONFIRMED
  ORDER_CLOSED
  PAYMENT_REJECTED
  DISPUTE_OPENED
  PENDING
  CONFIRMED
  PROCESSING
  CANCELLED
  REFUNDED
  COMPLETED
}

enum OrderItemStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  REVIEW
  APPROVED
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum InvoiceStatus {
  ISSUED
  PAID
  VOID
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  WALLET
  INSTALLMENT
}

enum PaymentPurpose {
  PLATFORM_FEE
  FULL_PAYMENT
  REFUND
}

enum ShippingStatus {
  PENDING
  PROCESSING
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  PURCHASE
  REFUND
  COMMISSION
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
}

enum AddressType {
  HOME
  WORK
  OTHER
}

enum NotificationType {
  ORDER_CREATED
  ORDER_CONFIRMED
  ORDER_SHIPPED
  ORDER_DELIVERED
  DELIVERY_CONFIRMED
  ORDER_CANCELLED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  DISPUTE_OPENED
  DISPUTE_UPDATED
  KYC_APPROVED
  KYC_REJECTED
  RFQ_RECEIVED
  RFQ_QUOTED
  SECURITY_ALERT
  WITHDRAWAL_COMPLETED
  REVIEW_RECEIVED
  MESSAGE_RECEIVED
  PRODUCT_OUT_OF_STOCK
  PRICE_CHANGE
  PROMOTION
  SYSTEM
}

enum ReviewStatus {
  ACTIVE
  HIDDEN
  FLAGGED
}

enum SupplierVerificationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum VerificationDocumentType {
  ID_DOCUMENT
  BUSINESS_REGISTRATION
  PHONE_PROOF
  ADDRESS_PROOF
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
